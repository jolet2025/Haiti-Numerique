":{"route":null,"timeSpentMetaData":null},"additional_roots":[],"client_id":"7613772828550639121","rootElementID":"mount_0_0_uf","expectedPreloaders":null,"initialRouteInfo":{"route":{"actorID":"0","rootView":{"allResources":[{"__dr":"CometVideoHomeLOEVideoPermalinkRoot.react"},{"__dr":"CometVideoHomeLOEVideoPermalinkRoot.entrypoint"},{"__dr":"CometVideoHomeRoot.react"},{"__dr":"CometVideoHomeFeedRoot.react"},{"__dr":"CometVideoHomeNewPermalinkHeroUnit.react"}],"resource":{"__dr":"CometVideoHomeLOEVideoPermalinkRoot.react"},"props":{"pageID":"100064680249728","upstreamPlayerSource":null,"v":"624208763501827","t":0,"focuscommentid":null,"injectionChainingVariables":{"scale":1,"trigger_data":{"injection_type":"WWW_RELATED_VIDEOS","search_keywords":null,"video_id":"624208763501827"}},"showHashtagPillsSidePane":false,"enableSeoWebCrawlerVideoTracks":false},"entryPoint":{"__dr":"CometVideoHomeLOEVideoPermalinkRoot.entrypoint"}},"tracePolicy":"comet.watch.injection","meta":{"title":"L'H\u00f4pital Universitaire de Mirebalais (HUM), qui est une bou\u00e9e de sauvetage pour les Ha\u00eftiens pendant plus d'une d\u00e9cennie, b\u00e9n\u00e9ficie d\u00e9sormais d'une modernisation r\u00e9volutionnaire de son syst\u00e8me solaire, achev\u00e9e malgr\u00e9 des d\u00e9fis importants.\n\nCe passage aux \u00e9nergies renouvelables garantit une alimentation \u00e9lectrique fiable pour les services essentiels comme les interventions chirurgicales et les soins intensifs.\n\nLa modernisation permet \u00e9galement d'\u00e9conomiser plus de 700 000 dollars par an, des fonds qui sont r\u00e9investis dans des soins vitaux et dans la formation des futurs professionnels de la sant\u00e9 ha\u00eftiens.\n\nApprenez-en plus sur cette initiative transformatrice : https:\/\/act.pih.org\/haiti-solar?utm_campaign=4486828-EOY\u0025202024\u002520Solar\u002520x\u002520ZL&utm_medium=email&_hsenc=p2ANqtz-_dLhpr3XxCkg0zl8AipU6fKBDqJudLPQaFGqo7dhegLqkfwRqTv0-s3eHoAYNBa31G9AvasS2qIl6t_iBLldsxUgjdbg&_hsmi=